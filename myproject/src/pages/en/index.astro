---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t.nav.home}>
  <section class="hero">
    <img src="/logo.svg" alt="She Shapes Tech" class="hero-logo" />
    <p class="subtitle">{t.home.subtitle}</p>
    <p class="intro">{t.home.intro}</p>
  </section>

  <section class="cards">
    <a href={getLocalizedPath('/events', lang)} class="card">
      <div class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      </div>
      <h3>{t.nav.events}</h3>
      <p>{t.events.home_desc}</p>
    </a>

    <a href={getLocalizedPath('/about', lang)} class="card">
      <div class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <h3>{t.nav.about}</h3>
      <p>{t.about.mission}</p>
    </a>

    <a href={getLocalizedPath('/contact', lang)} class="card">
      <div class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>
      <h3>{t.nav.contact}</h3>
      <p>{t.contact.subtitle}</p>
    </a>
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: 700px;
    margin: 0 auto;
    padding: 5rem 1.5rem 3rem;
    text-align: center;
  }

  .hero-logo {
    width: 280px;
    margin-bottom: 1.5rem;
  }

  .subtitle {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--primary);
    margin-bottom: 1rem;
  }

  .intro {
    font-size: 1rem;
    color: var(--muted-foreground);
    max-width: 560px;
    margin: 0 auto;
  }

  .cards {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .card {
    background: var(--muted);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 20px rgba(108, 134, 204, 0.15);
    transform: translateY(-2px);
  }

  .card-icon {
    width: 44px;
    height: 44px;
    background: var(--primary);
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .card-icon svg {
    width: 22px;
    height: 22px;
  }

  .card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--foreground);
  }

  .card p {
    font-size: 0.9rem;
    color: var(--muted-foreground);
    line-height: 1.6;
  }
</style>