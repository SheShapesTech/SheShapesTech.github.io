---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t.events.title}>
  <div class="page">
    <div class="page-header">
      <h1>{t.events.title}</h1>
      <p class="subtitle">{t.events.subtitle}</p>
    </div>

    <div class="events-list">
      <div class="event-card">
        <div class="event-date-badge">
          <span class="day">11</span>
          <span class="month">{t.events.christmas_month}</span>
        </div>
        <div class="event-info">
          <h3>{t.events.christmas_title}</h3>
          <p>{t.events.christmas_desc}</p>
        </div>
        <a href="https://teams.microsoft.com/..." target="_blank" class="event-btn">
          {t.events.learn_more} →
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--foreground);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--primary);
    font-weight: 600;
    font-size: 1.1rem;
  }

  .events-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .event-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--muted);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: all 0.2s;
  }

  .event-card:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 20px rgba(108, 134, 204, 0.15);
  }

  .event-date-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--primary);
    color: white;
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    min-width: 56px;
    text-align: center;
    flex-shrink: 0;
  }

  .day {
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1;
  }

  .month {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-top: 0.2rem;
  }

  .event-info {
    flex: 1;
  }

  .event-info h3 {
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 0.35rem;
  }

  .event-info p {
    font-size: 0.9rem;
    color: var(--muted-foreground);
  }

  .event-btn {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--primary);
    white-space: nowrap;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }

  .event-btn:hover {
    opacity: 0.7;
  }

  @media (max-width: 600px) {
    .event-card {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>