---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t.sponsors.title}>
  <div class="page">
    <div class="page-header">
      <h1>{t.sponsors.title}</h1>
      <p class="subtitle">{t.sponsors.subtitle}</p>
    </div>

    <p class="intro">{t.sponsors.intro}</p>

    <div class="sponsors-grid">
      <div class="sponsor-card">
        <div class="sponsor-logo-placeholder">SVIN</div>
        <div class="sponsor-info">
          <h3>SVIN</h3>
          <p>Schweizerischer Verband der Ingenieurinnen — unterstützt Frauen in technischen Berufen.</p>
        </div>
      </div>
    </div>

    <div class="become-sponsor">
      <h2>{t.sponsors.become_title}</h2>
      <a href="mailto:sheshapestech.engineering@zhaw.ch" class="cta-btn">
        {t.sponsors.become_cta} →
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--foreground);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--primary);
    font-weight: 600;
    font-size: 1.1rem;
  }

  .intro {
    color: var(--muted-foreground);
    margin-bottom: 3rem;
    font-size: 1rem;
  }

  .sponsors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .sponsor-card {
    background: var(--muted);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: all 0.2s;
  }

  .sponsor-card:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 20px rgba(108, 134, 204, 0.15);
  }

  .sponsor-logo-placeholder {
    height: 80px;
    background: var(--border);
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: var(--muted-foreground);
    font-size: 1.2rem;
  }

  .sponsor-info h3 {
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .sponsor-info p {
    font-size: 0.9rem;
    color: var(--muted-foreground);
  }

  .become-sponsor {
    text-align: center;
    padding: 3rem;
    background: var(--muted);
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }

  .become-sponsor h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .cta-btn {
    display: inline-block;
    background: var(--primary);
    color: white;
    font-weight: 700;
    padding: 0.75rem 2rem;
    border-radius: 9999px;
    transition: background 0.2s;
  }

  .cta-btn:hover {
    background: var(--primary-dark);
  }
</style>