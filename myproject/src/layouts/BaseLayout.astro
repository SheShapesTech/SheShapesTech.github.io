---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const switchLang = lang === 'de' ? 'en' : 'de';
const switchPath = lang === 'de'
  ? '/en' + (currentPath === '/' ? '' : currentPath)
  : currentPath.replace(/^\/en/, '') || '/';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = 'She Shapes Tech',
  description = 'She Shapes Tech — Netzwerk für Studentinnen an der ZHAW School of Engineering. Vernetzung, Events und gegenseitige Unterstützung.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = Astro.url.href;
const ogImageURL = new URL(ogImage, Astro.url.origin).href;
const pageTitle = `${title} | She Shapes Tech`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>

  <!-- SEO -->
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:site_name" content="She Shapes Tech" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --primary: #6c86cc;
      --primary-dark: #5570b8;
      --foreground: #28292a;
      --background: #ffffff;
      --muted: #f4f6fb;
      --muted-foreground: #6b7280;
      --border: #e5e9f5;
      --radius: 0.75rem;
      --font: 'Nunito', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font);
      background: var(--background);
      color: var(--foreground);
      line-height: 1.6;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    main { flex: 1; }

    a { color: inherit; text-decoration: none; }

    img { max-width: 100%; }
  </style>
</head>
<body>
  <header>
    <div class="header-inner">
      <a href={getLocalizedPath('/', lang)} class="logo">
        <img src="/logo.svg" alt="She Shapes Tech" height="36" />
      </a>

      <nav>
        <a href={getLocalizedPath('/', lang)} class={currentPath === '/' || currentPath === '/en' || currentPath === '/en/' ? 'active' : ''}>{t.nav.home}</a>
        <a href={getLocalizedPath('/events', lang)} class={currentPath.includes('/events') ? 'active' : ''}>{t.nav.events}</a>
        <a href={getLocalizedPath('/about', lang)} class={currentPath.includes('/about') ? 'active' : ''}>{t.nav.about}</a>
        <a href={getLocalizedPath('/sponsors', lang)} class={currentPath.includes('/sponsors') ? 'active' : ''}>{t.nav.sponsors}</a>
        <a href={getLocalizedPath('/contact', lang)} class={currentPath.includes('/contact') ? 'active' : ''}>{t.nav.contact}</a>
      </nav>

      <div class="header-right">
        <a href={switchPath} class="lang-switch">
          {switchLang.toUpperCase()}
        </a>
        <button class="mobile-menu-btn" id="menuBtn" aria-label="Toggle menu">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <nav class="mobile-nav" id="mobileNav">
      <a href={getLocalizedPath('/', lang)} onclick="document.getElementById('mobileNav').classList.remove('open')">{t.nav.home}</a>
      <a href={getLocalizedPath('/events', lang)} onclick="document.getElementById('mobileNav').classList.remove('open')">{t.nav.events}</a>
      <a href={getLocalizedPath('/about', lang)} onclick="document.getElementById('mobileNav').classList.remove('open')">{t.nav.about}</a>
      <a href={getLocalizedPath('/sponsors', lang)} onclick="document.getElementById('mobileNav').classList.remove('open')">{t.nav.sponsors}</a>
      <a href={getLocalizedPath('/contact', lang)} onclick="document.getElementById('mobileNav').classList.remove('open')">{t.nav.contact}</a>
      <a href={switchPath}>{switchLang.toUpperCase()}</a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <div class="footer-inner">
      <div class="footer-left">
        <p>{t.footer.rights}</p>
        <p class="footer-disclaimer">{t.footer.disclaimer}</p>
        <div class="footer-legal">
          <a href={getLocalizedPath('/impressum', lang)}>{t.footer.impressum}</a>
          <span aria-hidden="true">·</span>
          <a href={getLocalizedPath('/datenschutz', lang)}>{t.footer.datenschutz}</a>
        </div>
      </div>
      <div class="footer-social">
        <span>{t.footer.follow}</span>
        <a href="https://teams.microsoft.com/l/channel/19%3AXi784Ms6NohX6oO0abKqMh0Py_Kr3x9U7NtXGiziwyM1%40thread.tacv2/General?groupId=c9022015-7217-4b42-a31d-dd1ae8f6bc8e&tenantId=5d1a9f9d-201f-4a10-b983-451cf65cbc1e" target="_blank" rel="noopener noreferrer" aria-label="MS Teams">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </a>
        <a href="https://www.instagram.com/sheshapestech/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
      </div>
    </div>
  </footer>

  <style>
    header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(255,255,255,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }

    .header-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--foreground);
      white-space: nowrap;
    }

    nav {
      display: flex;
      gap: 1.5rem;
    }

    nav a {
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--muted-foreground);
      transition: color 0.2s;
    }

    nav a:hover, nav a.active {
      color: var(--primary);
    }

    .header-right {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .lang-switch {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--primary);
      border: 2px solid var(--primary);
      border-radius: 9999px;
      padding: 0.2rem 0.7rem;
      transition: all 0.2s;
    }

    .lang-switch:hover {
      background: var(--primary);
      color: white;
    }

    .mobile-menu-btn {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--foreground);
    }

    .mobile-nav {
      display: none;
      flex-direction: column;
      padding: 1rem 1.5rem;
      border-top: 1px solid var(--border);
      gap: 1rem;
    }

    .mobile-nav.open {
      display: flex;
    }

    .mobile-nav a {
      font-weight: 500;
      color: var(--muted-foreground);
    }

    .mobile-nav a:hover {
      color: var(--primary);
    }

    footer {
      border-top: 1px solid var(--border);
      padding: 1.5rem;
    }

    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
      font-size: 0.875rem;
      color: var(--muted-foreground);
    }

    .footer-left {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    .footer-disclaimer {
      font-size: 0.8rem;
      color: var(--muted-foreground);
      max-width: 480px;
    }

    .footer-legal {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      font-size: 0.8rem;
    }

    .footer-legal a {
      color: var(--muted-foreground);
      text-decoration: underline;
      text-decoration-color: var(--border);
      transition: color 0.2s;
    }

    .footer-legal a:hover {
      color: var(--primary);
      text-decoration-color: var(--primary);
    }

    .footer-social {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .footer-social a {
      color: var(--muted-foreground);
      transition: color 0.2s;
    }

    .footer-social a:hover {
      color: var(--primary);
    }

    @media (max-width: 768px) {
      nav { display: none; }
      .mobile-menu-btn { display: block; }
    }
  </style>

  <script>
    document.getElementById('menuBtn')?.addEventListener('click', () => {
      document.getElementById('mobileNav')?.classList.toggle('open');
    });
  </script>
</body>
</html>