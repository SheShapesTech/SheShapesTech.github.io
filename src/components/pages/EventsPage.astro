---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const today = new Date();
today.setHours(0, 0, 0, 0);

type EventItem = {
  id: string;
  date: string;
  day: string;
  month: string;
  subtitle: string;
  title: string;
  desc: string;
  date_display: string;
  map_url: string;
  location: string;
  details: string;
  register_url: string;
  ics_url: string;
};

const allEvents = (t.events.list as EventItem[]).sort(
  (a, b) => new Date(a.date).getTime() - new Date(b.date).getTime()
);
const upcoming = allEvents.filter(e => new Date(e.date) >= today);
const past = allEvents.filter(e => new Date(e.date) < today);
---

<BaseLayout title={t.events.title} description={t.events.description}>
  <div class="page">
    <div class="page-header">
      <h1>{t.events.title}</h1>
      <p class="subtitle">{t.events.subtitle}</p>
    </div>

    <div class="events-list">
      {upcoming.length > 0 ? (
        upcoming.map((event) => (
          <div class="event-card">
            <div class="event-date-badge">
              <span class="day">{event.day}</span>
              <span class="month">{event.month}</span>
            </div>
            <div class="event-info">
              <p class="event-collab">{event.subtitle}</p>
              <h3>{event.title}</h3>
              <p class="event-desc">{event.desc}</p>
              <ul class="event-meta">
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {event.date_display}
                </li>
                <li>
                  <a href={event.map_url} target="_blank" rel="noopener noreferrer" class="meta-map-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {event.location}
                  </a>
                </li>
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  {event.details}
                </li>
              </ul>
              <div class="event-actions">
                <a href={event.register_url} target="_blank" rel="noopener noreferrer" class="btn-primary">
                  {t.events.register} →
                </a>
                <a href={event.ics_url} download class="btn-secondary">
                  {t.events.save_date}
                </a>
              </div>
            </div>
          </div>
        ))
      ) : (
        <div class="empty-state">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <p>{t.events.empty_state}</p>
        </div>
      )}

      {past.length > 0 && (
        <details class="past-events">
          <summary>{t.events.past_title}</summary>
          <div class="past-events-list">
            {past.map((event) => (
              <div class="event-card past">
                <div class="event-date-badge">
                  <span class="day">{event.day}</span>
                  <span class="month">{event.month}</span>
                </div>
                <div class="event-info">
                  <p class="event-collab">{event.subtitle}</p>
                  <h3>{event.title}</h3>
                  <p class="event-desc">{event.desc}</p>
                  <ul class="event-meta">
                    <li>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      {event.date_display}
                    </li>
                    <li>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                      {event.location}
                    </li>
                    <li>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                      {event.details}
                    </li>
                  </ul>
                </div>
              </div>
            ))}
          </div>
        </details>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  h1 {
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--foreground);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--primary);
    font-weight: 500;
    font-size: 1.05rem;
  }

  .events-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Empty state */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 3rem 1.5rem;
    color: var(--muted-foreground);
    text-align: center;
  }

  .empty-state svg {
    width: 40px;
    height: 40px;
    color: var(--border);
  }

  .empty-state p {
    font-size: 1rem;
    font-style: italic;
  }

  /* Event cards */
  .event-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--muted);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: all 0.2s;
  }

  .event-card:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 20px rgba(108, 134, 204, 0.15);
  }

  .event-card.past {
    opacity: 0.6;
  }

  .event-card.past:hover {
    border-color: var(--border);
    box-shadow: none;
    opacity: 0.75;
  }

  .event-date-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--primary);
    color: white;
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    min-width: 56px;
    text-align: center;
    flex-shrink: 0;
  }

  .event-card.past .event-date-badge {
    background: var(--muted-foreground);
  }

  .day {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1;
  }

  .month {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-top: 0.2rem;
  }

  .event-info {
    flex: 1;
  }

  .event-collab {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .event-card.past .event-collab {
    color: var(--muted-foreground);
  }

  .event-info h3 {
    font-weight: 700;
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }

  .event-desc {
    font-size: 0.9rem;
    color: var(--muted-foreground);
    margin-bottom: 1rem;
  }

  .event-meta {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  .event-meta li,
  .event-meta a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--muted-foreground);
  }

  .event-meta svg {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    color: var(--primary);
  }

  .event-card.past .event-meta svg {
    color: var(--muted-foreground);
  }

  .meta-map-link {
    text-decoration: underline;
    text-decoration-color: var(--border);
    transition: color 0.2s;
  }

  .meta-map-link:hover {
    color: var(--primary);
    text-decoration-color: var(--primary);
  }

  .event-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    font-size: 0.875rem;
    font-weight: 700;
    background: var(--primary);
    color: white;
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    transition: background 0.2s;
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: var(--primary-dark);
  }

  .btn-secondary {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--primary);
    border: 2px solid var(--primary);
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .btn-secondary:hover {
    background: var(--primary);
    color: white;
  }

  /* Past events collapsible */
  .past-events {
    margin-top: 0.5rem;
  }

  .past-events summary {
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--muted-foreground);
    padding: 0.75rem 0;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    user-select: none;
  }

  .past-events summary::-webkit-details-marker {
    display: none;
  }

  .past-events summary::before {
    content: '▶';
    font-size: 0.65rem;
    transition: transform 0.2s;
  }

  .past-events[open] summary::before {
    transform: rotate(90deg);
  }

  .past-events summary:hover {
    color: var(--foreground);
  }

  .past-events-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 0.5rem;
  }

  .past-events .event-card.past {
    margin: 0;
  }

  @media (max-width: 600px) {
    .event-card {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
