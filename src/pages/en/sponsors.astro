---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t.sponsors.title} description={t.sponsors.description}>
  <div class="page">
    <div class="page-header">
      <h1>{t.sponsors.title}</h1>
      <p class="subtitle">{t.sponsors.subtitle}</p>
    </div>

    <p class="intro">{t.sponsors.intro}</p>

    <div class="sponsors-grid">
      <a href="https://www.zhaw.ch/de/engineering" target="_blank" rel="noopener noreferrer" class="sponsor-card">
        <div class="sponsor-logo-area">
          <img src="/zhaw_blue.png" alt="ZHAW" />
        </div>
        <div class="sponsor-info">
          <h3>ZHAW School of Engineering</h3>
          <p>{t.sponsors.zhaw_desc}</p>
        </div>
      </a>
      <a href="https://www.svin.ch/" target="_blank" rel="noopener noreferrer" class="sponsor-card">
        <div class="sponsor-logo-area">
          <img src="/svin_logo.svg" alt="SVIN" />
        </div>
        <div class="sponsor-info">
          <h3>SVIN</h3>
          <p>{t.sponsors.svin_desc}</p>
        </div>
      </a>
    </div>

    <div class="funding-section">
      <h2>{t.sponsors.funding_title}</h2>
      <p class="funding-claim">{t.sponsors.funding_claim}</p>
      <div class="funding-logos">
        <img src="/zhaw_blue.png" alt="ZHAW" class="funding-logo funding-logo--zhaw" />
        <img src="/swissuniversities-vector-logo.png" alt="swissuniversities" class="funding-logo funding-logo--swissuniversities" />
      </div>
    </div>

    <div class="become-sponsor">
      <h2>{t.sponsors.become_title}</h2>
      <a href="mailto:sheshapestech.engineering@zhaw.ch" class="cta-btn">
        {t.sponsors.become_cta} →
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--foreground);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--primary);
    font-weight: 500;
    font-size: 1.05rem;
  }

  .intro {
    color: var(--muted-foreground);
    margin-bottom: 3rem;
    font-size: 1rem;
  }

  .sponsors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .sponsor-card {
    background: var(--muted);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.2s;
  }

  .sponsor-card:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 20px rgba(108, 134, 204, 0.15);
  }

  .sponsor-logo-area {
    background: white;
    border-bottom: 1px solid var(--border);
    padding: 1.75rem 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 110px;
  }

  .sponsor-logo-area img {
    max-height: 60px;
    max-width: 100%;
    object-fit: contain;
  }

  .sponsor-info {
    padding: 1.25rem 1.5rem;
  }

  .sponsor-info h3 {
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .sponsor-info p {
    font-size: 0.9rem;
    color: var(--muted-foreground);
    line-height: 1.5;
  }

  .become-sponsor {
    text-align: center;
    padding: 3rem;
    background: var(--muted);
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }

  .become-sponsor h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .cta-btn {
    display: inline-block;
    background: var(--primary);
    color: white;
    font-weight: 700;
    padding: 0.75rem 2rem;
    border-radius: 9999px;
    transition: background 0.2s;
  }

  .cta-btn:hover {
    background: var(--primary-dark);
  }

  .funding-section {
    border-top: 1px solid var(--border);
    padding-top: 3rem;
    margin-bottom: 3rem;
  }

  .funding-section h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--foreground);
  }

  .funding-claim {
    font-size: 0.9rem;
    color: var(--muted-foreground);
    margin-bottom: 1.5rem;
  }

  .funding-logos {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .funding-logo {
    object-fit: contain;
    display: block;
  }

  .funding-logo--zhaw {
    height: 48px;
    width: auto;
  }

  .funding-logo--swissuniversities {
    height: 36px;
    width: auto;
  }

</style>